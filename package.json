{
  "name": "pi-pi-pi",
  "version": "0.1.0",
  "description": "Personal pi coding agent extensions, skills, keybindings, and settings",
  "type": "module",
  "scripts": {
    "postinstall": "node install.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "pi-package",
    "pi-extension"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ],
    "themes": [
      "./themes"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "^0.70.6",
    "@mariozechner/pi-tui": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49"
  }
}
